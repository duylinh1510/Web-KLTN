PORT=3000

# ===== Text2Cypher / AI engine (NgrokAiService) =====
AI_PROVIDER=mock
AI_BASE_URL=https://your-ngrok-url.ngrok-free.app
AI_TIMEOUT_MS=180000

# Text2Cypher Colab endpoint (Qwen2 + LoRA, từ Text2Cypher/ngrok_test.py)
TEXT2CYPHER_URL=https://your-text2cypher-ngrok.ngrok-free.app

# ===== CSV2Graph =====
# URL ngrok của Colab chạy python-services/colab/csv2graph_colab.py
# (Colab CHỈ host LLM Llama-3.2-3B-Instruct, expose /classify-schema)
CSV2GRAPH_LLM_URL=https://your-csv2graph-ngrok.ngrok-free.app

# Timeout cho call /classify-schema sang Colab (ms)
CSV2GRAPH_TIMEOUT_MS=300000

# URL của Python sidecar chạy local (FastAPI port 8001)
# python-services/csvtograph_sidecar.py — build data.pt từ preprocessed.csv + schema.json
CSV2GRAPH_SIDECAR_URL=http://127.0.0.1:8001
CSV2GRAPH_SIDECAR_TIMEOUT_MS=600000

# Folder lưu output theo jobId (relative process.cwd())
CSV2GRAPH_OUTPUT_DIR=data/csv2graph

# Cap số node mỗi relation group trước khi build star topology
CSV2GRAPH_MAX_GROUP_SIZE=500

# Batch size khi UNWIND ingest Neo4j
CSV2GRAPH_NODE_BATCH_SIZE=5000
CSV2GRAPH_EDGE_BATCH_SIZE=10000

# auto / true / false — auto sẽ tự detect bằng CALL apoc.help(...)
CSV2GRAPH_USE_APOC=auto
